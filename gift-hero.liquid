{% comment %} Custom "Gift Guide – Hero" section {% endcomment %}
<section class="gift-hero">
  <div class="gift-hero__bg">
    {% if section.settings.bg != blank %}
      {{ section.settings.bg | image_url: width: 2400 | image_tag: loading: 'lazy', class: 'gift-hero__img', alt: section.settings.title }}
    {% endif %}
  </div>

  <div class="gift-hero__content page-width">
    {% if section.settings.eyebrow != blank %}
      <p class="gift-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.title != blank %}
      <h1 class="gift-hero__title">{{ section.settings.title }}</h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="gift-hero__text rte">{{ section.settings.text }}</div>
    {% endif %}

    {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
      <a href="{{ section.settings.cta_url }}" class="gift-hero__btn">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>
</section>

<style>
.gift-hero {
  position: relative;
  isolation: isolate;
  padding: clamp(2rem, 6vw, 5rem) 0;
  overflow: hidden;
  text-align: center;
}
.gift-hero__bg {
  position: absolute;
  inset: 0;
  z-index: -1;
}
.gift-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(.95);
}
.gift-hero__content {
  max-width: 900px;
  margin: 0 auto;
}
.gift-hero__eyebrow {
  text-transform: uppercase;
  letter-spacing: .12em;
  font-size: .75rem;
  opacity: .75;
  margin: 0 0 .5rem;
}
.gift-hero__title {
  margin: .25rem 0 1rem;
  font-size: 2rem;
  font-weight: bold;
}
.gift-hero__text {
  margin-bottom: 1.25rem;
}
.gift-hero__btn {
  display: inline-block;
  padding: .75rem 1.25rem;
  border: 1px solid currentColor;
  border-radius: .5rem;
  text-decoration: none;
}
</style>

{% schema %}
{
  "name": "Gift guide hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Gift Guide" },
    { "type": "text", "id": "title", "label": "Title", "default": "How to gift well" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Curated picks for everyone on your list.</p>" },
    { "type": "image_picker", "id": "bg", "label": "Background image" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop all gifts" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ],
  "presets": [{ "name": "Gift guide hero" }]
}
{% endschema %}
