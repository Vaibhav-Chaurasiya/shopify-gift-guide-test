{% comment %} Custom "Gift Products Grid" section {% endcomment %}
<section class="gift-grid page-width">
  {% if section.settings.heading != blank %}
    <h2 class="gift-grid__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="gift-grid__products grid">
    {% for block in section.blocks %}
      {% if block.type == 'product' %}
        {% assign product = all_products[block.settings.product] %}
        {% if product %}
          <div class="gift-grid__item grid__item">
            <a href="{{ product.url }}" class="gift-grid__link">
              {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'gift-grid__img', alt: product.title }}
              <h3 class="gift-grid__title">{{ product.title }}</h3>
              <span class="gift-grid__price">{{ product.price | money }}</span>
            </a>
          </div>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
.gift-grid {
  padding: 2rem 0;
}
.gift-grid__heading {
  text-align: center;
  margin-bottom: 2rem;
}
.gift-grid__products {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
}
.gift-grid__item {
  border: 1px solid #eee;
  padding: 1rem;
  text-align: center;
}
.gift-grid__img {
  max-width: 100%;
  height: auto;
  margin-bottom: .75rem;
}
.gift-grid__title {
  font-size: 1rem;
  margin: .25rem 0;
}
.gift-grid__price {
  font-weight: bold;
  color: #333;
}
</style>

{% schema %}
{
  "name": "Gift products grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Picks we love" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Choose product" }
      ]
    }
  ],
  "presets": [{ "name": "Gift products grid" }]
}
{% endschema %}
